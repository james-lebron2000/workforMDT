# ===== App =====
APP_ENV=development
APP_SECRET=change-me-to-random-64-chars

# ===== Database =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tumorboard
POSTGRES_USER=tumorboard
POSTGRES_PASSWORD=change-me

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== MinIO (S3 兼容) =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=tumorboard
MINIO_SECRET_KEY=change-me-to-random
MINIO_BUCKET=tumorboard
MINIO_SECURE=false
MINIO_REGION=us-east-1
# 对外可访问的 endpoint(供浏览器 presigned URL 上传)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ===== AI Services =====
# V3 默认全云端:OCR 走火山 general_basic,ASR 走火山豆包音频理解 API
# 无需自部署 GPU 节点。如要退回 V1/V2 自部署链路,见下方注释。

# OCR:仅当 OCR_SERVICE_URL 非空时启用自部署 PaddleOCR(V1 legacy 路径)
# OCR_SERVICE_URL=http://ai-gpu:8001

# ASR provider 路由:"volcengine" (默认,豆包音频理解 API) | "funasr" (自部署 GPU)
ASR_PROVIDER=volcengine
# 仅当 ASR_PROVIDER=funasr 时需要,指向自部署 FunASR 服务
ASR_SERVICE_URL=http://ai-gpu:8002
# 火山豆包音频理解(全模态理解模型) — 参考 https://www.volcengine.com/docs/82379/2377589
# 控制台 endpoint 页面可复制确切 API ID;以下为占位,部署前填实际值
DOUBAO_AUDIO_MODEL=doubao-seed-2.0-lite

# ===== 火山引擎 OCR (general_basic) =====
# 控制台:https://console.volcengine.com/iam/keymanage  → 子用户加 CVFullAccess
# 文档:https://www.volcengine.com/docs/6790/116813
# 免费额度:5000 次/月,超出 0.005 元/次
VOLCENGINE_AK=
VOLCENGINE_SK=

# ===== LLM Provider 切换 =====
# 可选: doubao | qwen | kimi | claude | gpt
# V2 架构:OCR 走火山 general_basic(图→文字),LLM 只负责文本理解 — 任何 provider 都行。
# 仅当你想启用 run_ocr_vision_agent 备选路径(火山覆盖不到的手写/复杂版式)时,
# 才需要 provider 支持 vision 输入:doubao-seed-1-6 / qwen-vl-max / gpt-4o / kimi-vision
LLM_PROVIDER=doubao
LLM_FALLBACK_PROVIDERS=qwen,kimi

# 豆包(火山方舟 Ark)
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# 通义千问
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# Kimi
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-32k

# Claude
CLAUDE_BASE_URL=https://api.anthropic.com/v1
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI / GPT
GPT_BASE_URL=https://api.openai.com/v1
GPT_API_KEY=
GPT_MODEL=gpt-4o-mini

# ===== 微信(可选,MVP 可先关) =====
WECHAT_APPID=
WECHAT_SECRET=

# ===== 隐私保留期(天) =====
RETENTION_DAYS_RAW=30      # 原图/原音频归档
RETENTION_DAYS_FULL=365    # 彻底删除
